{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "allowJs": true,
        "allowSyntheticDefaultImports": true,
        "incremental": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "module": "esnext",
        "noEmit": true,
        "plugins": [
            {
                "name": "next"
            }
        ],
        "strict": false,
        "esModuleInterop": true
    },
    "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", "**/*.md", "**/*.mdx", ".next/types/**/*.ts"],
    "exclude": ["node_modules"]
}
