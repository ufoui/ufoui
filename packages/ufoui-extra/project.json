{
  "name": "@ufoui/extra",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/ufoui-extra/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "test": {
      "executor": "@nx/vite:test",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "configFile": "packages/ufoui-extra/vite.config.ts",
        "passWithNoTests": true
      }
    },
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/ufoui-extra",
        "configFile": "packages/ufoui-extra/vite.config.ts"
      }
    }
  }
}
